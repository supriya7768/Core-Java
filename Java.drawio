        <mxCell id="MjDqHjWN7hwCDv39jjPg-2" value="For each&amp;nbsp; -&amp;gt;&amp;nbsp; Take one item&amp;nbsp; -&amp;gt;&amp;nbsp; store in temp&amp;nbsp; -&amp;gt; use it&amp;nbsp; -&amp;gt;&amp;nbsp; repeat" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
