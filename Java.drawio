        </mxCell>
        <mxCell id="mriFYcUJs7z9-BHMGoYr-18" value="&lt;ol&gt;&lt;li&gt;Underline data structure - Growable Array&lt;/li&gt;&lt;li&gt;Insertion order preservred&lt;/li&gt;&lt;li&gt;Duplicate elements allowed&lt;/li&gt;&lt;li&gt;Null insertion is allowed&lt;/li&gt;&lt;li style=&quot;&quot;&gt;Homogeneous/ Heterogeneous objects allowed&lt;/li&gt;&lt;/ol&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="465" y="-615" width="330" height="100" as="geometry" />
