        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-16" value="LinkedHashMap" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3080" y="-630" width="90" height="15" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-18" value="LinkedHashMap = HashMap + Doubly Linked List&lt;div&gt;Developers wanted store data like HashMap but manintain&amp;nbsp; insertion order&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3080" y="-600" width="410" height="30" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-19" value="Its internal working is similarly like HashMap just one diffference&lt;div&gt;Suppose we write :&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;b&gt;Map&amp;lt;Integer,String&amp;gt; map =&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;new LinkedHashMap&amp;lt;&amp;gt;();&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;map.put(101,&quot;John&quot;);&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;map.put(102,&quot;Mike&quot;);&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;map.put(103,&quot;David&quot;);&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3080" y="-552.5" width="500" height="105" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-20" value="In LinkedHashMap one special node i created&lt;div&gt;&lt;div&gt;Entry{&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;key=101,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;value=John,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;next,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;before,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;after&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3080" y="-429.37" width="350" height="159.37" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-21" value="before, after are extra pointers&lt;div&gt;Extra before after consumes more memory&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3230" y="-342.5" width="260" height="42.5" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-22" value="Internally :&lt;div&gt;&lt;br&gt;&lt;div&gt;&lt;div&gt;Bucket Structure&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Bucket[5] ---&amp;gt; Node101&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Bucket[6] ---&amp;gt; Node102&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Bucket[7] ---&amp;gt; Node103&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Add simulataneously:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Linked List&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Node101 &amp;lt;-&amp;gt; Node102 &amp;lt;-&amp;gt; Node103&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3080" y="-280" width="620" height="220" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-24" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" vertex="1" parent="1">
          <mxGeometry x="3080" y="-50" width="274" height="520" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-25" value="" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="3490" y="-637.5" width="400" height="132.5" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-26" value="&lt;ol&gt;&lt;li&gt;&amp;nbsp;Capacity = 16&amp;nbsp; &amp;nbsp;Load factor = 0.75&lt;/li&gt;&lt;li&gt;Underline data structure&amp;nbsp; - HashMap and Doubly Linked List&lt;/li&gt;&lt;li&gt;Insertion order is preserved&lt;/li&gt;&lt;li&gt;Duplicate keys are not allowed but values can be duplicate&lt;/li&gt;&lt;li&gt;Heterogeneous/Homogeneous object are allowed&lt;/li&gt;&lt;li&gt;Null is allowed for key only once, Values can have multiple null.&lt;/li&gt;&lt;/ol&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3480" y="-627.5" width="400" height="100" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-28" value="" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="3490" y="-483.75" width="410" height="103.75" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-29" value="Constructors :&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;LinkedHashMap m&amp;nbsp; = new LinkedHashMap&amp;nbsp;();&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;LinkedHashMap&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;/span&gt;l = new LinkedHashMap&amp;nbsp;&amp;nbsp;(int initialCapacity);&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;LinkedHashMap&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;/span&gt;l = new LinkedHashMap&amp;nbsp;(int initialCapacity, float fillRatio);&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;LinkedHashMap&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;/span&gt;l = new LinkedHashMap&amp;nbsp;(Map m);&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3501.25" y="-465" width="418.75" height="70" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-30" value="" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="3070" y="590" width="890" height="1470" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-32" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="3080" y="600" width="60" height="20" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-33" value="TreeMap" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3080" y="602.5" width="60" height="15" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-34" value="" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="3510" y="620" width="420" height="130" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-35" value="&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;ol&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Underline datastructure - Red Black tree&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Insertion order is not preserved&lt;/span&gt;&lt;/li&gt;&lt;li&gt;Duplicate keys are not allowed but values can be duplicate&lt;/li&gt;&lt;li&gt;Homogeneous object are allowed&lt;/li&gt;&lt;li&gt;Null is not allowed for key from Java 1.7, Values can have multiple null.&lt;/li&gt;&lt;/ol&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3500" y="630" width="420" height="100" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-36" value="&lt;span style=&quot;font-style: normal;&quot;&gt;TreeMap internally uses Red Black Tree. generally used for sorting order&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;When we write:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;b style=&quot;font-style: normal;&quot;&gt;TreeMap&amp;lt;Integer, String&amp;gt; map = new TreeMap&amp;lt;&amp;gt;();&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;Intially root = null. TreeMap is empty&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;Insert a element :&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;b style=&quot;font-style: normal;&quot;&gt;map.put(50, &quot;John&quot;);&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;root = 50&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;Insert second element :&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;b style=&quot;font-style: normal;&quot;&gt;map.put(30, &quot;Mike&quot;);&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;TreeMap compares 30 &amp;lt; 50. Go left&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; 50&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;/&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;&amp;nbsp; &amp;nbsp;30&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;Insert third element :&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;&lt;b&gt;map.put(70, &quot;David&quot;);&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;Compare 70 &amp;gt; 50. Go right&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; 50&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;/&amp;nbsp; &amp;nbsp; \&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;&amp;nbsp; &amp;nbsp;30&amp;nbsp; &amp;nbsp; 70&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;Insert fourth element :&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;&lt;b&gt;map.put(40, &quot;A&quot;);&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;Compare 40 &amp;lt;50. Go left&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;Compare 40 &amp;gt; 30. Go right&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; 50&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;/&amp;nbsp; &amp;nbsp; &amp;nbsp;\&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;&amp;nbsp; &amp;nbsp;30&amp;nbsp; &amp;nbsp; 70&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;\&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-style: normal;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; 40&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="3090" y="630" width="450" height="490" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-37" value="Note : Treemap does not use hashcode() or equals()&lt;div&gt;TreeMap uses compareTo()&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3290" y="890" width="290" height="50" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-38" value="&lt;u&gt;How get() works ?&lt;/u&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Suppose &lt;b&gt;map.get(40);&lt;/b&gt;&lt;/div&gt;&lt;div&gt;TreeMap starts from root&lt;/div&gt;&lt;div&gt;40 &amp;lt; 50. Go left&lt;/div&gt;&lt;div&gt;40 &amp;gt; 30 . Go right&lt;/div&gt;&lt;div&gt;Found 40.&amp;nbsp; &amp;nbsp; Return value&lt;/div&gt;&lt;div&gt;No hashing. Only comparison&lt;/div&gt;&lt;div&gt;Time complexity 0(log n)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;u&gt;Why 0(log n)?&lt;/u&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Suppose Tree :&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;50&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;/&amp;nbsp; &amp;nbsp; \&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;30&amp;nbsp; &amp;nbsp; &amp;nbsp; 70&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; /&amp;nbsp; \&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;/&amp;nbsp; &amp;nbsp;\&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; 20&amp;nbsp; &amp;nbsp;40 60&amp;nbsp; &amp;nbsp;80&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Searching :&lt;/div&gt;&lt;div&gt;&lt;div&gt;50&lt;/div&gt;&lt;div&gt;↓&lt;/div&gt;&lt;div&gt;30&lt;/div&gt;&lt;div&gt;↓&lt;/div&gt;&lt;div&gt;40&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Only few comparisons. Not every node. Therefore 0(log n)&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3090" y="1140" width="610" height="385" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-39" value="&lt;u&gt;How sorting happens ?&lt;/u&gt;&lt;div&gt;&lt;u&gt;&lt;br&gt;&lt;/u&gt;&lt;/div&gt;&lt;div&gt;Because every insertion follows :&lt;/div&gt;&lt;div&gt;&lt;div&gt;Smaller -&amp;gt; Left&lt;/div&gt;&lt;div&gt;Greater -&amp;gt; Right&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Example :&lt;/div&gt;&lt;div&gt;&lt;div&gt;map.put(50,&quot;A&quot;);&lt;/div&gt;&lt;div&gt;map.put(20,&quot;B&quot;);&lt;/div&gt;&lt;div&gt;map.put(80,&quot;C&quot;);&lt;/div&gt;&lt;div&gt;map.put(10,&quot;D&quot;);&amp;nbsp; &amp;nbsp;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Tree:&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; 50&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;/&amp;nbsp; &amp;nbsp; &amp;nbsp;\&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;20&amp;nbsp; &amp;nbsp; 80&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; /&lt;/div&gt;&lt;div&gt;&amp;nbsp; 10&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;When TreeMap prints it performs Inorder Traversal&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Rule :&lt;/div&gt;&lt;div&gt;&lt;div&gt;Left&lt;/div&gt;&lt;div&gt;Root&lt;/div&gt;&lt;div&gt;Right&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Output :&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;div&gt;10&lt;/div&gt;&lt;div&gt;20&lt;/div&gt;&lt;div&gt;50&lt;/div&gt;&lt;div&gt;80&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;Automatically sorted&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3080" y="1550" width="600" height="450" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-40" value="&lt;u&gt;Duplicate keys :&lt;/u&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;map.put(101,&quot;John&quot;);&lt;/div&gt;&lt;div&gt;map.put(101,&quot;Mike&quot;);&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;TreeMap compares with comapreTo()&amp;nbsp; &amp;nbsp; &amp;nbsp;Result = 0&lt;/div&gt;&lt;div&gt;Means same key. Value updated 101 -&amp;gt; Mike&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;u&gt;Null Key :&lt;/u&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;map.put(null,&quot;ABC&quot;);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Throws NullPointerException&lt;/div&gt;&lt;div&gt;Why? TreeMap needs compareTo() to compare keys. Null cannot be compared&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3530" y="1800" width="380" height="220" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-41" value="&lt;u&gt;Each node contains&lt;/u&gt; :&lt;div&gt;&lt;div&gt;key&lt;/div&gt;&lt;div&gt;value&lt;/div&gt;&lt;div&gt;left&lt;/div&gt;&lt;div&gt;right&lt;/div&gt;&lt;div&gt;parent&lt;/div&gt;&lt;div&gt;color&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3570" y="1020" width="250" height="110" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-42" value="" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="2680" y="2280" width="1170" height="1270" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-43" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="2700" y="2300" width="160" height="20" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-44" value="Comparable vs Comparator" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="2700" y="2302.5" width="160" height="15" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-45" value="Comparable is used when a class wants to define its natural/default sorting order. It provides the compareTo() method.&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Comparator is used when we need custom sorting logic. It provides the compare() method and allows multiple sorting strategies without modifying the original class.&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="2700" y="2330" width="455" height="90" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-46" value="First understand the problem :&lt;div&gt;Suppose we have :&amp;nbsp;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;List&amp;lt;Integer&amp;gt; list =&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Arrays.asList(50,10,30,20);&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Java already knowshoow to sort Integers :&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b&gt;Collections.sort(list);&amp;nbsp;&lt;/b&gt; &amp;nbsp;-&amp;gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;10 20 30 50&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Now supppose we have :&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;div&gt;&lt;b&gt;class Employee {&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; int id;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; String name;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;}&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;b&gt;Employee e1 = new Employee(103,&quot;John&quot;);&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Employee e2 = new Employee(101,&quot;Mike&quot;);&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Employee e3 = new Employee(102,&quot;David&quot;);&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Now&amp;nbsp;&lt;b&gt;Collections.sort(employeeList);&lt;/b&gt;&lt;/div&gt;&lt;div&gt;How should Java sort Employees?&lt;/div&gt;&lt;div&gt;By :&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;id ?&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;div&gt;name ?&lt;/div&gt;&lt;div&gt;salary ?&lt;/div&gt;&lt;div&gt;age ?&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;u&gt;Comparable :&lt;/u&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;p data-end=&quot;1018&quot; data-start=&quot;1012&quot;&gt;Think:&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Comparable means the object itself knows how to compare itself with another object.&lt;/span&gt;&lt;/p&gt;&lt;p data-end=&quot;1018&quot; data-start=&quot;1012&quot;&gt;&lt;b&gt;class Employee implements Comparable&amp;lt;Employee&amp;gt; {&lt;/b&gt;&lt;/p&gt;&lt;p data-end=&quot;1018&quot; data-start=&quot;1012&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; int id;&lt;/b&gt;&lt;/p&gt;&lt;p data-end=&quot;1018&quot; data-start=&quot;1012&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; String name;&lt;/b&gt;&lt;/p&gt;&lt;p data-end=&quot;1018&quot; data-start=&quot;1012&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; @Override&lt;/b&gt;&lt;/p&gt;&lt;p data-end=&quot;1018&quot; data-start=&quot;1012&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; public int compareTo(Employee e) {&lt;/b&gt;&lt;/p&gt;&lt;p data-end=&quot;1018&quot; data-start=&quot;1012&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; return this.id - e.id;&lt;/b&gt;&lt;/p&gt;&lt;p data-end=&quot;1018&quot; data-start=&quot;1012&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; }&lt;/b&gt;&lt;/p&gt;&lt;p data-end=&quot;1018&quot; data-start=&quot;1012&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;/span&gt;&lt;/b&gt;&lt;/p&gt;&lt;p data-end=&quot;1018&quot; data-start=&quot;1012&quot;&gt;&lt;b&gt;}&lt;/b&gt;&lt;/p&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Now Employee is saying if anyone wants to sort me sort using id&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Sort : &lt;b&gt;Collections.sort(employeeList);&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Java internally calls&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b&gt;e1.compareTo(e2)&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;Comparison : 103-101&amp;nbsp; &amp;nbsp;Result =2 Meaning : Positive 103 comes after 101&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="2700" y="2430" width="570" height="660" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-47" value="&lt;u&gt;How compareTo() works ?&lt;/u&gt;&lt;div&gt;public int compareTo(Employee e)&lt;/div&gt;&lt;div&gt;Must return :&lt;/div&gt;&lt;div&gt;1. return -1 (Negative) current object comes before&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; Example 10.compareTo(20)&amp;nbsp; = -10 Means 10 before 20&lt;/div&gt;&lt;div&gt;2. return +1 (Positive) current object comes after&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; Example 20.compareTo(10) = 10 Means 20 after 10&lt;/div&gt;&lt;div&gt;3. return 0 both object are same&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="2700" y="3100" width="415" height="120" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-48" value="&lt;u&gt;Sort employee (Ascending) :&lt;/u&gt;&lt;div&gt;&lt;div&gt;&lt;b&gt;@Override&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;public int compareTo(Employee e) {&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; return this.id - e.id;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;}&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;u&gt;Sort employee (decending)&lt;/u&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;b&gt;@Override&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;public int compareTo(Employee e) {&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; return e.id - this.id;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;}&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="2700" y="3240" width="335" height="200" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-49" value="&lt;u&gt;Limitations :&lt;/u&gt;&lt;div&gt;Using Comparable compareTo() you can define only ONE default sorting logic. Suppose here we only sort by id what if tomorrow we need to sort by salary or name. Then there comes Comparator.&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="2692.5" y="3450" width="350" height="80" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-50" value="" style="endArrow=none;html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="3240" y="3530" as="sourcePoint" />
            <mxPoint x="3240" y="2332.5" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-51" value="Comparable : Object compares itself&lt;div&gt;Comparator : Somebody else compares objects.&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3250" y="2330" width="465" height="40" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-52" value="Example :&lt;div&gt;&lt;div&gt;&lt;b&gt;class Employee {&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp;int id;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp;String name;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp;double salary;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;}&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3255" y="2375" width="235" height="120" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-53" value="No comparable" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3391.25" y="2470" width="110" height="30" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-54" value="Create Comparator :&lt;div&gt;&lt;div&gt;&lt;b&gt;class EmployeeIdComparator&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;implements Comparator&amp;lt;Employee&amp;gt; {&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp;@Override&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp;public int compare(Employee e1,&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;Employee e2) {&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; return e1.id - e2.id;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp;}&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;}&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;Sort :&amp;nbsp;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Collections.sort(&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;list,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;new EmployeeIdComparator()&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;);&amp;nbsp; &amp;nbsp;&lt;/b&gt; &amp;nbsp; &amp;nbsp; Output : 101,102,103&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3250" y="2510" width="505" height="155" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-55" value="Another Comparator :&lt;div&gt;&lt;div&gt;&lt;b&gt;class EmployeeNameComparator&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;implements Comparator&amp;lt;Employee&amp;gt; {&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp;@Override&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp;public int compare(Employee e1,&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;Employee e2) {&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; return e1.name.compareTo(e2.name);&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp;}&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;}&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;Sort :&amp;nbsp;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Collections.sort(&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;list,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;new EmployeeNameComparator()&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;&lt;b&gt;);&amp;nbsp; &amp;nbsp;&lt;/b&gt;&amp;nbsp;&amp;nbsp; &amp;nbsp; Output : David,John, Mike&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3250" y="2700" width="545" height="150" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-56" value="Another Comparator&lt;div&gt;&lt;div&gt;&lt;b&gt;class EmployeeSalaryComparator&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;implements Comparator&amp;lt;Employee&amp;gt; {&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp;@Override&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp;public int compare(Employee e1,&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Employee e2) {&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; return Double.compare(&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; e1.salary,&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; e2.salary);&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp;}&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;}&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;Sort :&amp;nbsp;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Collections.sort(&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;list,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;new EmployeeSalaryComparator()&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;&lt;b&gt;);&amp;nbsp; &amp;nbsp;&lt;/b&gt;&amp;nbsp;&amp;nbsp; &amp;nbsp; Output : 20000, 50000, 80000&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3248.75" y="2901.77" width="571.25" height="100" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-57" value="&lt;u&gt;Why Comparator is powerful ?&lt;/u&gt;&lt;div&gt;One class Employee can have sort by ID, sort by name, sort by salary, sort by age, sort by department. Unlimited sorting logic.&lt;/div&gt;&lt;div&gt;TreeMap uses compare() to decide left or right in the Red Black Tree&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3250" y="3060" width="425" height="60" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-58" value="&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Comparable&lt;/th&gt;&lt;th&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Comparator&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;Package: java.lang&lt;/td&gt;&lt;td&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Package: java.util&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;compareTo()&lt;/td&gt;&lt;td&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; compare()&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Inside class&lt;/td&gt;&lt;td&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Outside class&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;One sorting logic&lt;/td&gt;&lt;td&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Multiple sorting logic&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Modifies class&lt;/td&gt;&lt;td&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; No modification needed&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Default sorting&lt;/td&gt;&lt;td style=&quot;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;Custom sorting&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="3248.75" y="3150" width="270" height="140" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-59" value="" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="2490" y="450" width="470" height="260" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-60" value="No override needed for equals() and hashcode() needed when using built in immutable types :&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;String&lt;/span&gt;&lt;div&gt;Integer&lt;/div&gt;&lt;div&gt;Long&lt;/div&gt;&lt;div&gt;Double&lt;/div&gt;&lt;div&gt;BigDecimal&lt;/div&gt;&lt;div&gt;LocalDate&lt;/div&gt;&lt;div&gt;UUID&lt;/div&gt;&lt;/div&gt;&lt;div&gt;because they already override them&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Override needed if we are using custom classes :&lt;/div&gt;&lt;div&gt;Employee&lt;/div&gt;&lt;div&gt;Student&lt;/div&gt;&lt;div&gt;Order&lt;/div&gt;&lt;div&gt;Product&lt;/div&gt;&lt;div&gt;Customer&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="2521.25" y="470" width="399.37" height="220" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-61" value="" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="90" y="1460" width="799.5" height="960" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-62" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="100" y="1470" width="130" height="20" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-63" value="Fail-fast vs Fail-safe" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="100" y="1472.5" width="130" height="15" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-64" value="Suppose we have :&lt;div&gt;&lt;div&gt;&lt;b&gt;List&amp;lt;String&amp;gt; list = new ArrayList&amp;lt;&amp;gt;();&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;list.add(&quot;Java&quot;);&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;list.add(&quot;Spring&quot;);&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;list.add(&quot;Hibernate&quot;);&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;b&gt;for(String s : list){&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; System.out.println(s);&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;}&amp;nbsp;&lt;/b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;Output : Java, Spring Hibernate&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;And if suppose we did this&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;b&gt;for(String s : list){&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; list.add(&quot;Microservices&quot;);&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; System.out.println(s);&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/b&gt;&amp;nbsp;Output : ConcurrentModificationException&lt;/div&gt;&lt;div&gt;&lt;b&gt;}&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Now think Iteraor is reading data and collection is changing it.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Should iterator continue?&lt;/span&gt;&lt;/div&gt;&lt;div&gt;Should it stop?&lt;/div&gt;&lt;div&gt;Should it read old data?&lt;/div&gt;&lt;div&gt;Should it read new data?&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&amp;nbsp;This situation can create inconsistent results.&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="107" y="1498.75" width="429.5" height="300" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-65" value="" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="587.87" y="1487.5" width="245.75" height="242.5" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-66" value="&lt;u&gt;Collections using fail-fast :&lt;/u&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;ArrayList&lt;/div&gt;&lt;div&gt;LinkedList&lt;/div&gt;&lt;div&gt;HashMap&lt;/div&gt;&lt;div&gt;HashSet&lt;/div&gt;&lt;div&gt;LinkedHashMap&lt;/div&gt;&lt;div&gt;TreeMap&lt;/div&gt;&lt;div&gt;TreeSet&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;u&gt;Collections using fail-safe&lt;/u&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;CopyOnWriteArrayList&lt;/div&gt;&lt;div&gt;ConcurrrentHashMap&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="618" y="1498.75" width="151.5" height="220" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-68" value="&lt;u&gt;Why Exception occurs?&lt;/u&gt;&lt;div&gt;&lt;u&gt;&lt;br&gt;&lt;/u&gt;&lt;/div&gt;&lt;div&gt;Every collection contains a hidden variable&amp;nbsp; - modCount Think: Modification Counter&amp;nbsp;&lt;/div&gt;&lt;div&gt;Example :&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;b&gt;ArrayList&amp;lt;String&amp;gt; list =&amp;nbsp;&lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;&amp;nbsp;new ArrayList&amp;lt;&amp;gt;()&lt;/b&gt;;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Initially modcount = 0&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Add first element &lt;b&gt;list.add(&quot;Java&quot;);&lt;/b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; modCount =1&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Add second element &lt;b&gt;list.add(&quot;Spring&quot;);&amp;nbsp;&lt;/b&gt; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;modcount = 2&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Add third element &lt;b&gt;list.add(&quot;Hibernate&quot;);&amp;nbsp; &amp;nbsp;&lt;/b&gt; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;modcount&amp;nbsp; = 3&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;Iterator creation :&lt;/div&gt;&lt;div&gt;&lt;b&gt;Iterator&amp;lt;String&amp;gt; itr = list.iterator();&amp;nbsp; &lt;/b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Iterator stores expectedModCount = =3&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Current state modCount =3&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; expectedModCOunt = 3&lt;/div&gt;&lt;div&gt;During iteration &lt;b&gt;itr.next();&lt;/b&gt;&lt;/div&gt;&lt;div&gt;Iterator checks is(modCount != expectedModCount)&amp;nbsp; &amp;nbsp; 3==3&amp;nbsp; &amp;nbsp; &amp;nbsp;Continue&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Now if we do this &lt;b&gt;list.add(&quot;Microservices&quot;);&lt;/b&gt;&lt;/div&gt;&lt;div&gt;Collections modCount =4&amp;nbsp;&lt;/div&gt;&lt;div&gt;But iterator still has expectedModCount =3&amp;nbsp;&lt;/div&gt;&lt;div&gt;Next iteration &lt;b&gt;itr.next();&lt;/b&gt;&lt;/div&gt;&lt;div&gt;checks is(modCount != expectedModCount)&amp;nbsp; &amp;nbsp; 4 != 3&amp;nbsp; &amp;nbsp; &amp;nbsp; ConcurrentModificationException&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="107" y="1807.5" width="492.5" height="315" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-69" value="&lt;u&gt;Why Java do this ?&lt;/u&gt;&lt;div&gt;&lt;u&gt;&lt;br&gt;&lt;/u&gt;&lt;div&gt;To prevent:&lt;/div&gt;&lt;div&gt;&lt;div&gt;Data Corruption&lt;/div&gt;&lt;div&gt;Infinite Loops&lt;/div&gt;&lt;div&gt;Missing Elements&lt;/div&gt;&lt;div&gt;Duplicate Reads&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="108.75" y="2140" width="152.5" height="100" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-70" value="Fails immediately. Hence fail-fast" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="291.75" y="2170" width="205.75" height="30" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-71" value="&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Feature&lt;/th&gt;&lt;th&gt;Fail-Fast&lt;/th&gt;&lt;th&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;Fail-Safe&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;Collection modified during iteration&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&lt;/td&gt;&lt;td&gt;Exception&lt;/td&gt;&lt;td&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;No Exception&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Uses Original Collection&lt;/td&gt;&lt;td&gt;Yes&lt;/td&gt;&lt;td&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;No&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Uses Snapshot Copy&lt;/td&gt;&lt;td&gt;No&amp;nbsp; &amp;nbsp;&lt;/td&gt;&lt;td&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;Yes&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Memory Usage&lt;/td&gt;&lt;td&gt;Less&amp;nbsp;&amp;nbsp;&lt;/td&gt;&lt;td&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;More&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Performance&lt;/td&gt;&lt;td&gt;Faster&amp;nbsp;&lt;/td&gt;&lt;td&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;More Memory Cost&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;ConcurrentModificationException&lt;/td&gt;&lt;td&gt;Yes&lt;/td&gt;&lt;td style=&quot;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;No&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="114" y="2270" width="422.5" height="140" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-72" value="&lt;u&gt;Internal working of add() &lt;/u&gt;:&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Suppose &lt;b&gt;list.add(&quot;F&quot;);&lt;/b&gt;&lt;/div&gt;&lt;div&gt;Current Array [ &quot;A&quot;, &quot;B&quot;, &quot;C&quot;, &quot;D&quot;, &quot;E&quot;]&lt;/div&gt;&lt;div&gt;Acquire lock - &lt;b&gt;lock.lock()&amp;nbsp; &lt;/b&gt;&amp;nbsp; Only one writer allowed&lt;/div&gt;&lt;div&gt;Create new Array :&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;[ &quot;A&quot;, &quot;B&quot;, &quot;C&quot;, &quot;D&quot;, &quot;E&quot;, &quot;F&quot;]&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Update reference&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Release lock -&lt;b&gt; lock.unlock();&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Write uses&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;ReentrantLock&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="115" y="3060" width="282.5" height="130" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-73" value="Every write creates a brand new array :&lt;div&gt;&lt;div&gt;add()&lt;/div&gt;&lt;div&gt;remove()&lt;/div&gt;&lt;div&gt;set()&lt;/div&gt;&lt;div&gt;clear()&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="487.5" y="3060" width="141" height="100" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-74" value="No locking required for get()" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="112.5" y="3200" width="230.5" height="30" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-75" value="&lt;u&gt;When should we use it ?&lt;/u&gt;&lt;div&gt;&lt;div&gt;95% Read&lt;/div&gt;&lt;div&gt;5% Write&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Application Configuration&lt;/div&gt;&lt;div&gt;Country Codes&lt;/div&gt;&lt;div&gt;Currency List&lt;/div&gt;&lt;div&gt;State Master Data&lt;/div&gt;&lt;div&gt;Cache Reference Data&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="110.75" y="3240" width="303.5" height="130" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-76" value="&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Feature&lt;/th&gt;&lt;th&gt;ArrayList&lt;/th&gt;&lt;th&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;CopyOnWriteArrayList&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;Thread Safe&lt;/td&gt;&lt;td&gt;No&lt;/td&gt;&lt;td&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Yes&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Read Performance&lt;/td&gt;&lt;td&gt;Fast&lt;/td&gt;&lt;td&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Fast&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Write Performance&lt;/td&gt;&lt;td&gt;Fast&lt;/td&gt;&lt;td&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Slow&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Iterator&lt;/td&gt;&lt;td&gt;Fail-Fast&lt;/td&gt;&lt;td&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Snapshot Based&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;ConcurrentModificationException&lt;/td&gt;&lt;td&gt;Yes&lt;/td&gt;&lt;td&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;No&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Memory Usage&lt;/td&gt;&lt;td&gt;Less&lt;/td&gt;&lt;td style=&quot;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;More&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="110" y="3380" width="447.5" height="160" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-77" value="" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="114" y="3600" width="916" height="1400" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-78" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="131.25" y="3620" width="130" height="20" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-79" value="ConcurrentHashMap" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="131.25" y="3622.5" width="130" height="15" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-80" value="ConcurrentHashMap is basically a HashMap made safe for multiple threads&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;u&gt;Why wasn&#39;t HashMap enough?&lt;/u&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Suppose:&lt;/div&gt;&lt;div&gt;&lt;b&gt;HashMap&amp;lt;Integer,String&amp;gt; map = new HashMap&amp;lt;&amp;gt;();&lt;/b&gt;&lt;/div&gt;&lt;div&gt;Two threads execute simultaneously:&lt;/div&gt;&lt;div&gt;&lt;div&gt;Thread-1:&lt;/div&gt;&lt;div&gt;&lt;b&gt;map.put(101,&quot;John&quot;);&lt;/b&gt;&lt;/div&gt;&lt;div&gt;Thread-2:&lt;/div&gt;&lt;div&gt;&lt;b&gt;map.put(102,&quot;Mike&quot;);&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;Both may try to modify the same internal bucket array at the same time.&lt;/div&gt;&lt;div&gt;Result:&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;Corrupted Data&lt;/span&gt;&lt;/div&gt;&lt;div&gt;Lost Updates&lt;/div&gt;&lt;div&gt;Inconsistent State&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="131.25" y="3650" width="520" height="220" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-81" value="Suppose we wrrite :&lt;div&gt;&lt;div&gt;&lt;b&gt;ConcurrentHashMap&amp;lt;Integer,String&amp;gt; map =&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;new ConcurrentHashMap&amp;lt;&amp;gt;();&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Initially all buckets are empty.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b&gt;map.put(101,&quot;John&quot;);&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;Now ConcurrentHashMap must decide:&amp;nbsp;Which bucket?&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;Calculate hash : 101.hashcode()&amp;nbsp; &amp;nbsp;Return 101&lt;/div&gt;&lt;div&gt;Calculate bucket : (16 - 1) &amp;amp; 101&amp;nbsp; &amp;nbsp;Return : Bucket =5&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;ConcurrentHashMap checks:&amp;nbsp;Bucket[5] = null ?&amp;nbsp;Current: YES Empty bucket&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;This is the first major difference from HashMap.&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Instead of locking immediately:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;ConcurrentHashMap first tries:&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;CAS (Compare and swap) Think :&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&quot;If bucket is still empty,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;insert my node.&quot;&lt;/div&gt;&lt;div&gt;Thread -1 checks : still null ? - Yes Insert in bucket 5 without locking.&lt;/div&gt;&lt;div&gt;Why no lock ? Because&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;Empty Bucket&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;No Competition&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Another thread inserts&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;map.put(117,&quot;Mike&quot;);&lt;/span&gt;&lt;/div&gt;&lt;div&gt;Assume:&amp;nbsp;117 also maps to bucket 5. Collision&lt;/div&gt;&lt;div&gt;Current Bucket 5 -&amp;nbsp;(101,John). Not empty&lt;/div&gt;&lt;div&gt;Bucket not empty.&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Now CAS cannot help.&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Need modification.&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;ConcurrentHashMap locks ONLY Bucket 5.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Not whole map.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Visualization :&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;div style=&quot;&quot;&gt;Bucket 1&amp;nbsp; Free&lt;/div&gt;&lt;div style=&quot;&quot;&gt;Bucket 2&amp;nbsp; Free&lt;/div&gt;&lt;div style=&quot;&quot;&gt;Bucket 3&amp;nbsp; Free&lt;/div&gt;&lt;div style=&quot;&quot;&gt;Bucket 4&amp;nbsp; Free&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;Bucket 5&amp;nbsp; LOCKED&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;Bucket 6&amp;nbsp; Free&lt;/div&gt;&lt;div style=&quot;&quot;&gt;Bucket 7&amp;nbsp; Free&lt;/div&gt;&lt;div style=&quot;&quot;&gt;Bucket 8&amp;nbsp; Free&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 30%;&quot;&gt;&lt;p data-end=&quot;2796&quot; data-start=&quot;2788&quot;&gt;Current:&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;Bucket[5]&amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;101 -&amp;gt; John.&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Need to insert:&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;117 -&amp;gt; Mike&lt;/span&gt;&lt;/p&gt;&lt;p data-end=&quot;2796&quot; data-start=&quot;2788&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;ConcurrentHashMap checks:&amp;nbsp;equals()&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Duplicate key?&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;No.&lt;/span&gt;&lt;/p&gt;&lt;p data-end=&quot;2796&quot; data-start=&quot;2788&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Add node:&lt;/span&gt;&lt;/p&gt;&lt;p data-end=&quot;2796&quot; data-start=&quot;2788&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Bucket[5]&lt;/span&gt;&lt;/p&gt;&lt;p data-end=&quot;2796&quot; data-start=&quot;2788&quot;&gt;(101,John)&lt;/p&gt;&lt;p data-end=&quot;2796&quot; data-start=&quot;2788&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; |&lt;/p&gt;&lt;p data-end=&quot;2796&quot; data-start=&quot;2788&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; V&lt;/p&gt;&lt;p data-end=&quot;2796&quot; data-start=&quot;2788&quot;&gt;(117,Mike)&lt;/p&gt;&amp;nbsp;Unlock bucket. Done&lt;/div&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="132.5" y="3900" width="667.5" height="660" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-82" value="&lt;u&gt;Why it is faster than Hashtable?&lt;/u&gt;&lt;div style=&quot;line-height: 40%;&quot;&gt;&lt;p data-end=&quot;3096&quot; data-start=&quot;3088&quot;&gt;Imagine:&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Thread-1 modifying Bucket 5.&lt;/span&gt;&lt;/p&gt;&lt;br/&gt;&lt;p data-end=&quot;3143&quot; data-start=&quot;3128&quot;&gt;Simultaneously:&lt;/p&gt;&lt;br/&gt;&lt;p data-end=&quot;3174&quot; data-start=&quot;3145&quot;&gt;Thread-2 modifying Bucket 12.&lt;/p&gt;&lt;p data-end=&quot;3174&quot; data-start=&quot;3145&quot;&gt;Hashtable : Entire Map lock Thread 2 waits&lt;/p&gt;&lt;p data-end=&quot;3174&quot; data-start=&quot;3145&quot;&gt;ConcurrentHashMap : Bucket 5 locked&lt;/p&gt;&lt;p data-end=&quot;3174&quot; data-start=&quot;3145&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;Bucket 12 locked&lt;/p&gt;&lt;p data-end=&quot;3174&quot; data-start=&quot;3145&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;Both threads work simulataneously&lt;/p&gt;&lt;p data-end=&quot;3174&quot; data-start=&quot;3145&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;Huge performance impeovement&lt;/p&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="125" y="4570" width="503.5" height="200" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-83" value="For read get() :&lt;div&gt;NO LOCK&lt;/div&gt;&lt;div&gt;This is why ConcurrentHashMap is fast. Many readers can read together.&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="125" y="4770" width="478.75" height="60" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-84" value="" style="rounded=1;whiteSpace=wrap;html=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="662.5" y="3640" width="307.5" height="90" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-85" value="&lt;ol&gt;&lt;li&gt;Null key not allowed&lt;/li&gt;&lt;/ol&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="670" y="3650" width="269.26" height="30" as="geometry" />
        </mxCell>
        <mxCell id="-TBS4qTc4NiXvZP-rJ_w-86" value="Internal working in resizing :&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Suppose capacity 16 is full . Need 32&lt;/div&gt;&lt;div&gt;HashMap : One thread resizes other wait&lt;/div&gt;&lt;div&gt;CincurrentHashMap : Multiple threads can help resize. This is called Cooperative Resizing&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="132.5" y="4860" width="407.5" height="150" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
