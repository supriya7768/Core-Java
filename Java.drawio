        <mxCell id="mriFYcUJs7z9-BHMGoYr-32" value="&lt;ol&gt;&lt;li&gt;Underline data structure - Doubly Linked List&lt;/li&gt;&lt;li&gt;Insertion order is preserved&lt;/li&gt;&lt;li&gt;Duplicate object is allowed&lt;/li&gt;&lt;li&gt;Null isertion is allowed&lt;/li&gt;&lt;li&gt;Homogeneous/Hetregeneous object are allowed&lt;/li&gt;&lt;/ol&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="540" width="280" height="90" as="geometry" />
