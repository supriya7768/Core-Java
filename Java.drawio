        <mxCell id="MjDqHjWN7hwCDv39jjPg-4" value="&#xa;&lt;div style=&quot;font-family:&#39;Segoe UI&#39;;font-size:14px;font-style:normal;font-weight:400;line-height:20px&quot;&gt;nums array&#xa;   ↓&#xa;┌──────┐&#xa;│ 1    │ ───► x = 1 ───► print&#xa;│ 2    │ ───► x = 2 ───► print&#xa;│ 3    │ ───► x = 3 ───► print&#xa;└──────┘&#xa;   ↓&#xa;End of array → STOP ✅&lt;/div&gt;&#xa;&#xa;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="-700" y="540" width="220" height="240" as="geometry" />
