        </mxCell>
        <mxCell id="mriFYcUJs7z9-BHMGoYr-21" value="Constructors :&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;ArrayList l = new ArrayList();&lt;/div&gt;&lt;div&gt;ArrayList l = new Arraylist(int initialCapacity);&lt;/div&gt;&lt;div&gt;ArrayList l = new ArrayList(Collection c);&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
