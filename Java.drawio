        </mxCell>
        <UserObject label="&lt;span&gt;&lt;div class=&quot;scriptor-paragraph&quot;&gt;&lt;span&gt;int[] nums = {1, 2, 3};&lt;/span&gt;&lt;/div&gt;&lt;br class=&quot;scriptor-paragraph&quot;&gt;&lt;div class=&quot;scriptor-paragraph&quot;&gt;&lt;span&gt;for (int x : nums) {&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;scriptor-paragraph&quot;&gt;&lt;span&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp; System.out.println(x);&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;scriptor-paragraph&quot;&gt;&lt;span&gt;}&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;" link="&lt;span&gt;&lt;div class=&quot;scriptor-paragraph&quot;&gt;&lt;span&gt;int[] nums = {1, 2, 3};&lt;/span&gt;&lt;/div&gt;&lt;br class=&quot;scriptor-paragraph&quot;&gt;&lt;div class=&quot;scriptor-paragraph&quot;&gt;&lt;span&gt;for (int x : nums) {&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;scriptor-paragraph&quot;&gt;&lt;span&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp; System.out.println(x);&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;scriptor-paragraph&quot;&gt;&lt;span&gt;}&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;" id="MjDqHjWN7hwCDv39jjPg-1">
